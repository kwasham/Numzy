# Example environment configuration for the receipt processing API

# Set your OpenAI API key here to enable extraction and audit services
OPENAI_API_KEY=sk-your-openai-api-key

# The SQLAlchemy database URL
DATABASE_URL=postgresql+asyncpg://user:password@host/database

# Directory where uploaded receipts and assets are stored
STORAGE_DIRECTORY=./storage

# Development mode flag
DEV_AUTH_BYPASS=false

# Redis URL used by Dramatiq for task queue
DRAMATIQ_BROKER_URL=redis://redis:6379/0

# Stripe API key placeholder
STRIPE_API_KEY=sk-your-stripe-api-key

# Secret key for session management and JWTs
SECRET_KEY=your-secret-key

# MCP server URL
MCP_URL=http://mcp_server:8000

# Clerk authentication key
CLERK_SECRET_KEY=sk_test_your_clerk_key

# Test user JWT for development
TEST_USER_JWT=your-test-jwt
